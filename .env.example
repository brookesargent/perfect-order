# Copy this file to `.env` for local development:  cp .env.example .env
# `.env` is gitignored — never commit real secrets.
# On Render, you do NOT use this file: DATABASE_URL is injected from the database
# and ANTHROPIC_API_KEY is set as a secret in the dashboard.

# Your Anthropic API key. Get one at https://console.anthropic.com/
# If this is missing or invalid, the app still runs and serves a sample order.
ANTHROPIC_API_KEY=sk-ant-...

# Postgres connection string.
#  - Local Postgres:        postgres://localhost:5432/perfect_order
#  - Render (for local dev): paste the database's EXTERNAL connection string
#                            (it ends in .render.com and needs SSL — handled in db.js)
# Leave unset to run without persistence (save/list features just turn off).
DATABASE_URL=postgres://localhost:5432/perfect_order

# Local port. Render sets PORT automatically, so this only matters locally.
PORT=3000
